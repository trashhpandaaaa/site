# Copy to .env.local or set env vars in your shell before running the scripts
# Required by the app and API seeder:
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=public-anon-key

# Service role key (server-only). Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=service_role_...

# Gemini (Google Generative Language) — powers the AI chat at /chat and the
# Experience review auto-classification (server-only).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash

# Clerk auth keys (required for sign-in and posting).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...

# Upstash Redis (optional) — powers API rate limiting on chat/votes/posts.
# Without these, rate limiting is skipped (the app still works). Create a free
# database at https://console.upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Direct Postgres connection string for running DB migrations (db:migrate).
# Supabase dashboard -> Project Settings -> Database -> Connection string (URI).
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
